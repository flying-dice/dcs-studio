//! studio::cli — dcs-studio-cli, the agent-complete companion binary
//! (decisions/005). Everything an agent needs without the Tauri app:
//! scaffold projects, check workspaces, serve the genuine LSP, serve MCP.
//! The IDE's backend spawns `dcs-studio-cli lsp` as its language server.

/// One file produced by scaffolding, relative to the new project root.
public data TemplateFile { path: string, contents: string }

/// The dcs-studio-cli binary.
public container Cli for studio::core::Studio {
  /// Serve the Language Server Protocol over stdio: initialize walks the
  /// workspace root for Lua sources, edits arrive as full-document sync,
  /// findings publish per file. Speaks to any LSP client — editors, the
  /// IDE's backend host, LLM agents.
  #[manual]
  public Lsp(): void;

  /// Serve MCP over stdio (newline-delimited JSON-RPC): `init_project`
  /// and `check` tools first; build, deploy, and introspection tools
  /// follow their phases.
  #[manual]
  public Mcp(): void;

  /// Scaffold a project from a named template into `<parent>/<name>`:
  /// refuse an existing target, materialise every template file, return
  /// the new root. Same templates the app's New Project flow offers.
  #[manual]
  public Init(template: string, parent: string, name: string): Result<string, studio::files::IoError> {
    known = bool from self.HasTemplate(template)
    if (!known) {
      unknown = studio::files::IoError from { template }
      return Err(unknown)
    }
    files = studio::cli::TemplateFile[] from self.RenderTemplate(template, name)
    root = Result<string, studio::files::IoError> from self.Materialise(parent, name, files)
    if (root.isErr) {
      return Err(root.error)
    }
    return Ok(root.value)
  }

  /// Whether a template id is registered (lua-script-mod today; the Rust
  /// DLL mod joins with issue #6 R1).
  HasTemplate(template: string): bool;

  /// Render a template's file set, substituting the project name.
  RenderTemplate(template: string, name: string): studio::cli::TemplateFile[];

  /// Create `<parent>/<name>` and write every file beneath it, refusing
  /// to overwrite an existing root.
  Materialise(parent: string, name: string, files: studio::cli::TemplateFile[]): Result<string, studio::files::IoError>;

  /// Analyse a workspace and print findings; the exit code is the number
  /// of error-severity findings, so agents and CI can gate on it.
  #[manual]
  public Check(root: string): number {
    files = dcslua::SourceUnit[] from self.CollectSources(root)
    findings = syntax::Diagnostic[] from dcslua::DcsLuaLs.Analyse(files)
    errors = number from self.CountErrors(findings)
    return errors
  }

  /// Every .lua / .d.lua under the root, skipping vendor/VCS directories.
  CollectSources(root: string): dcslua::SourceUnit[];

  /// Error-severity findings in the list.
  CountErrors(findings: syntax::Diagnostic[]): number;
}

/// An agent bootstraps and validates a mod without the app.
feature AgentWorksWithoutTheApp for studio::cli::Cli {
  given "only the dcs-studio-cli binary on PATH"
  when "an agent runs init, edits Lua, and runs check"
  then "a valid project scaffold appears"
  and "check reports the agent's syntax mistakes with stable codes"
  and "the exit code gates on error findings"
}

/// The same engine answers every surface.
feature OneEngineEverySurface for studio::cli::Cli {
  given "a workspace with one broken Lua file"
  when "it is analysed via check, via the MCP check tool, and via the LSP"
  then "all three report the same finding with the same code and span"
}
