{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dcs-studio",
  "version": "0.1.0",
  "identifier": "com.jonat.dcs-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm sidecar && pnpm build",
    "frontendDist": "../../build"
  },
  "app": {
    "windows": [
      {
        "title": "dcs-studio",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/lua-analyzer"
    ],
    "resources": [
      "dcs_studio.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["dcs-studio"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/flying-dice/dcs-studio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4QzFDOTQwMjU0MURBQUIKUldTcjJrRWxRTW5CR0trcnhrLy9YOE9rTUpnd2g1Y1lxblZ3U2VqSzNEK040TUtOaUhjT0R4R0MK"
    }
  }
}
