{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dcs-studio",
  "version": "0.1.0",
  "identifier": "com.jonat.dcs-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm sidecar && pnpm build",
    "frontendDist": "../../build"
  },
  "app": {
    "windows": [
      {
        "title": "dcs-studio",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["dcs-studio"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/lua-analyzer"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
